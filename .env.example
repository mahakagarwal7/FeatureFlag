# .env.example
# Copy this to .env and fill in your actual values
# NEVER commit .env to Git!

# OpenAI-compatible API (required for LLM agent)
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# Hugging Face (for Spaces deployment)
HF_TOKEN=your_huggingface_token_here
LOCAL_IMAGE_NAME=your_local_image_name

# Environment Configuration
ENV_HOST=0.0.0.0
ENV_PORT=8000
ENV_RELOAD=true

# Frontend origin allowlist for CORS (comma-separated)
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# API SECURITY (Optional - all disabled by default for backward compatibility)
# ============================================================================
# Set ENABLE_SECURITY=true to activate authentication and audit logging
ENABLE_SECURITY=false

# Require authentication (only enforced if ENABLE_SECURITY=true)
REQUIRE_AUTH=false

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
TOKEN_EXPIRY_HOURS=24

# API Key Configuration (format: user1=key1,user2=key2)
# Example: API_KEYS=agent1=secret-key-1,agent2=secret-key-2
API_KEYS=agent1=your-secure-api-key-1,agent2=your-secure-api-key-2

# Rate Limiting (enabled by default if ENABLE_SECURITY=true)
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Audit Logging (enabled by default if ENABLE_SECURITY=true)
ENABLE_AUDIT_LOGGING=true

# Audit Encryption (optional)
AUDIT_ENCRYPTION=true

# ============================================================================
# MONITORING & ALERTING (Optional - all enabled by default for observability)
# ============================================================================
# Set ENABLE_MONITORING=false to completely disable monitoring/metrics collection
ENABLE_MONITORING=true

# Enable alerting based on metric thresholds
ENABLE_ALERTING=true

# Export metrics in Prometheus format (for /metrics endpoint)
ENABLE_PROMETHEUS=true

# Alert Thresholds
ALERT_ERROR_RATE_THRESHOLD=0.05          # Alert if error rate > 5%
ALERT_LATENCY_THRESHOLD_MS=1000          # Alert if avg latency > 1 second
ALERT_HEALTH_SCORE_THRESHOLD=0.7         # Alert if health score < 70%

# Collection Intervals
METRICS_COLLECTION_INTERVAL=60            # Collect metrics every 60 seconds
ALERT_CHECK_INTERVAL=30                   # Check thresholds every 30 seconds

# ============================================================================
# SQLITE PERSISTENCE (Optional - disabled by default)
# ============================================================================
ENABLE_DATABASE=true
DATABASE_PATH=logs/app.db
DATABASE_TIMEOUT_SECONDS=5.0

# API Configuration (duplicated here for clarity in grouped sections)
# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini