# Required environment variables for submission
# Provider options: auto | openai | hf
LLM_PROVIDER=auto

API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here
HF_TOKEN=your_hf_or_api_token_here
HF_API_BASE_URL=https://router.huggingface.co/v1
# Optional explicit endpoint override:
# HF_CHAT_COMPLETIONS_URL=https://router.huggingface.co/v1/chat/completions
LOCAL_IMAGE_NAME=your_local_image_name

# Optional runtime variables
ENV_HOST=0.0.0.0
ENV_PORT=8000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENABLE_SECURITY=false
REQUIRE_AUTH=false
API_KEYS=agent1=your-secure-api-key-1,agent2=your-secure-api-key-2

# 🚀 GitHub Integration
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=your_repository_name

# 💬 Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#deployments
