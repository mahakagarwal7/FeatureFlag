# Copy this to .env and fill in your values
# NEVER commit .env to version control

# === LLM Configuration ===
LLM_PROVIDER=auto  # auto | openai | groq | hf
OPENAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
HF_TOKEN=your_hf_token_here
MODEL_NAME=gpt-4o-mini  # or llama3-8b-8192 for Groq

# === Server Configuration ===
ENV_HOST=0.0.0.0
ENV_PORT=8000
ENABLE_RELOAD=true

# === Database (Optional) ===
ENABLE_DATABASE=true
DATABASE_PATH=logs/app.db
DATABASE_TIMEOUT_SECONDS=5.0

ENABLE_SECURITY=false
REQUIRE_AUTH=false
JWT_SECRET=change-me-in-production
API_KEYS=agent1=key1,agent2=key2

# === Monitoring (Optional) ===
ENABLE_MONITORING=true
ENABLE_PROMETHEUS=true
ENABLE_ALERTING=true

# === Tool Integrations (Optional) ===
GITHUB_TOKEN=ghp_your_token
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_CHANNEL=#deployments

# === Debug Flags ===
FF_DEBUG_API=0
FF_DEBUG_MONITORING=0
FF_DEBUG_STATE_CLIP=0
